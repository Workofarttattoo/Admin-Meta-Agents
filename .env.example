# ── Admin Meta-Agents Environment Configuration ─────────────────────
# Copy to .env and fill in values before running.

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Maximum resources available to the agent pool (integer)
MAX_RESOURCES=10

# Feature flags
ENABLE_AUTO_SCALING=false
ENABLE_INCIDENT_ALERTS=false

# External integrations (optional)
# WEBHOOK_URL=https://hooks.example.com/agent-events
# API_KEY=your-api-key-here
# DATABASE_URL=postgresql://user:pass@localhost:5432/admin_agents
